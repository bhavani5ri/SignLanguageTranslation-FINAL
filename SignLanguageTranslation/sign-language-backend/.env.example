# ─────────────────────────────────────────────
#  Environment Variables — copy to .env
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/signlang_db?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-app.vercel.app
